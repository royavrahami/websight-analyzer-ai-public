# Copy this file to `.env` and fill in your values. Never commit `.env`.

# Anthropic Claude API key — required for the optional AI-powered analysis
# (core/advanced_analysis.py). Without it, AI features are disabled and the
# rest of the toolkit still works.
ANTHROPIC_API_KEY=

# OpenAI API key — optional, only needed if you enable OpenAI-based features.
OPENAI_API_KEY=

# Run browsers headless (true) or headed (false). Defaults to true.
BROWSER_HEADLESS=true
